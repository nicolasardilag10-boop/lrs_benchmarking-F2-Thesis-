xpos <- barplot(
quality_matrix,
beside = TRUE,                     # separate bars per group
ylim = c(0, 105),                  # percentage scale
ylab = "Reads meeting quality threshold (%)",
main = "FASTQ read quality: Q20 and Q30",
legend.text = TRUE,                # show legend
args.legend = list(
x = "bottomright",               # no box around legend
bty = "n"
),
las = 2                           # rotate x-axis labels
)
# Add horizontal reference lines (20%, 40%, 60%, 80%, 100%)
abline(
h = c(20, 40, 60, 80, 100),
lty = 3
)
abline(
h = c(0,20, 40, 60, 80, 100),
lty = 3
)
